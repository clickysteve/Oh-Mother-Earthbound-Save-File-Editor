# Python
__pycache__/
*.pyc
*.pyo

# User config (per-launch settings — not project-wide)
.eb_save_editor.json

# Local sandbox / scratch / research output that we don't want in the repo
_local/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Save backups (don't accidentally commit user save data)
*.srm
*.sav
*.bak
*.bak.srm

# Build artifacts
build/
dist/
*.egg-info/
# PyInstaller writes "Oh Mother.spec" on each build
*.spec
# Regenerated by ./make_icon.sh from icon-source.png — no need to ship the binary
AppIcon.icns
# Generated by the Windows release workflow from icon-source.png
AppIcon.ico
